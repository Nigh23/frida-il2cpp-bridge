{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2021"],
    "moduleResolution": "node",
    "outDir": "dist", // 只保留 outDir
    "sourceRoot": ".",
    "declaration": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "plugins": [ 
      { "transform": "ts-transformer-inline-file/transformer" }
    ],
    "rootDir": "./lib",
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["dist", "test", "example"]
}
