{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2021"],
    "moduleResolution": "node",
    "outDir": "dist",          // ✅ 仅保留 outDir，彻底移除冲突的 outFile
    "sourceRoot": ".",
    "declaration": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "plugins": [ 
      { "transform": "ts-transformer-inline-file/transformer" }
    ],
    "rootDir": "./lib"         // ✅ 显式指定源码根目录，解决布局问题
    // ❌ 移除了不被支持的 ignoreDeprecations 选项
  },
  "exclude": ["dist", "test", "example"]
}
